# =============================================================================
# LabReplay — Root .gitignore
# =============================================================================

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
*.pyo
build/
dist/
wheels/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Experimental / session data ───────────────────────────────────────────────
# Raw recorded session databases — too large and contain participant data
Data/
!Data/images/
!Data/images/platform.png

# SQLite session databases inside total-recall (large binary files)
total-recall/sessions/*.db
total-recall/*.db

# ── Temporary / scratch files ─────────────────────────────────────────────────
temp.py
*.tmp
*.log

# ── Word documents ────────────────────────────────────────────────────────────
# Checked in as markdown instead; .docx binary is not diff-friendly
*.docx

# ── C build artifacts (learning/ experiments) ─────────────────────────────────
learning/*.o
learning/a.out
learning/server
